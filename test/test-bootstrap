#!/usr/bin/env bash
set -euo pipefail

export DBX_CONTAINER_MANAGER=podman
IMAGE="${1:-ubuntu:24.04}"
NAME="test-dotfiles-$(date +%s)"

echo "Creating Distrobox: $NAME ($IMAGE) via Podman..."
distrobox create --name "$NAME" --image "$IMAGE" --yes

echo "Initializing container (triggers distrobox setup)..."
distrobox enter "$NAME" -- true

echo "Copying dotfiles in..."
podman start "$NAME"
podman exec "$NAME" mkdir -p /tmp/dotfiles
podman cp "$HOME/dotfiles/." "$NAME:/tmp/dotfiles/"

echo "Running install..."
podman exec "$NAME" bash -c '
  set -euo pipefail
  cp -r /tmp/dotfiles ~/dotfiles
  cd ~/dotfiles
  ./install.sh 2>&1
' | while IFS= read -r line; do echo "  $line"; done

echo ""
echo "=== Verifying ==="
podman exec "$NAME" bash -c '
  echo "Checking tools..."
  which tmux neovim fzf starship zoxide mise || true
  echo ""
  echo "Checking oh-my-zsh..."
  ls ~/.oh-my-zsh/ 2>/dev/null || echo "  oh-my-zsh not found"
  echo ""
  echo "Checking stow symlinks..."
  ls -la ~/.config/zsh/.zshrc ~/.config/git/config 2>/dev/null || echo "  symlinks not found"
  echo ""
  echo "=== Testing idempotency ==="
  cd ~/dotfiles && ./install.sh
' | while IFS= read -r line; do echo "  $line"; done

echo ""
echo "Cleaning up..."
distrobox stop "$NAME" --yes
distrobox rm "$NAME" --yes

echo "✓ All tests passed!"